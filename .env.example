# Copy this file to .env and fill in the values before running docker compose up.
# .env is gitignored — never commit real credentials.

# Required: Anthropic API key for RAG sidecar (Claude generation)
ANTHROPIC_API_KEY=sk-ant-...

# JWT signing secret — override with a long random string in production
JWT_SECRET=devSecretKeyForLocalDockerMustBeLongEnough123

# Optional: Gmail SMTP for email notifications
# Use a Gmail App Password (not your account password)
MAIL_USERNAME=your.email@gmail.com
MAIL_PASSWORD=your-app-password

# Optional: Snyk token for dependency vulnerability scanning
# Generate at https://app.snyk.io/account
SNYK_TOKEN=
